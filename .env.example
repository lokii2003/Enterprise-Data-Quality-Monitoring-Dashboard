# ── Copy this file to .env and fill in your real values ──────────────────────
# .env is git-ignored and must never be committed.

# Database backend
# Default: SQLite (no setup needed — data_quality_db1.db is created automatically)
# To switch to MySQL, uncomment these and update scripts to use mysql+pymysql://
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=data_quality_db1

# Email alerts (Gmail) — use an App Password, NOT your account password
# https://myaccount.google.com/apppasswords
SENDER_EMAIL=your_email@gmail.com
SENDER_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECEIVER_EMAIL=receiver@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
